wf := import("@platforma-sdk/workflow-tengo:workflow")
exec := import("@platforma-sdk/workflow-tengo:exec")
xsv := import("@platforma-sdk/workflow-tengo:pframes.xsv")
times := import("times")
pframes := import("@platforma-sdk/workflow-tengo:pframes")


wf.body(func(args) {
	// --- Main data: columns on "name" axis ---
	mainTsv := "name\tvalue\tscore\tcategory\tnote\n" +
		"A\t10\t1.5\tA\thello\n" +
		"B\t20\t2.7\tB\tworld\n" +
		"C\t30\t3.1\tA\tfoo\n" +
		"D\t40\t4.8\tB\tbar\n" +
		"E\t50\t5.0\tA\tbaz\n"

	// --- Linked data: columns on "group" axis ---
	groupTsv := "group\tdescription\tpriority\n" +
		"G1\tFirst group\t1\n" +
		"G2\tSecond group\t2\n"

	// --- Linker A: maps "name" -> "group" (group axis domain: source=primary) ---
	// Partial coverage — maps A,B,C only.
	linkerTsv := "name\tgroup\tlink\n" +
		"A\tG1\t1\n" +
		"B\tG1\t1\n" +
		"C\tG2\t1\n"

	// --- Linker B: second path "name" -> "group" (group axis domain: source=secondary) ---
	// Partial coverage — maps C,D,E only. Different group-axis domain than linker A.
	// Two linkers over the same (name, group) axis pair but with DIFFERENT group-axis
	// domains produce MatchVariants whose qualifications on the hit's group axis carry
	// distinct contextDomain values — populating `distinctiveQualifications` (non-empty
	// forHit) for each group-axis hit column. Feeds formatDistinctive in
	// deriveDistinctTooltips and withInfoAnnotations per-variant records.
	linkerAltTsv := "name\tgroup\tlinkAlt\n" +
		"C\tG2\t1\n" +
		"D\tG2\t1\n" +
		"E\tG1\t1\n"

	// --- Second-hop linked data: columns on "region" axis ---
	regionTsv := "region\tregionName\tpopulation\n" +
		"R1\tNorth\t1000\n" +
		"R2\tSouth\t2000\n"

	// --- Second linker: maps "group" -> "region" ---
	linker2Tsv := "group\tregion\tlink2\n" +
		"G1\tR1\t1\n" +
		"G2\tR2\t1\n"

	// --- Label columns: axis value -> human-readable label ---
	// participate in getMatchingLabelColumns / deriveAllLabels (createPlDataTableV3.ts#L106-110)
	// each has single axis and column name "pl7.app/label"
	nameLabelTsv := "name\tlabel\n" +
		"A\tAlpha sample\n" +
		"B\tBeta sample\n" +
		"C\tGamma sample\n" +
		"D\tDelta sample\n" +
		"E\tEpsilon sample\n"

	groupLabelTsv := "group\tlabel\n" +
		"G1\tGroup One\n" +
		"G2\tGroup Two\n"

	regionLabelTsv := "region\tlabel\n" +
		"R1\tNorth region\n" +
		"R2\tSouth region\n"

	e := exec.builder().
		cpu(1).ram("50Mi").
		cmd("env").
		writeFile("main.tsv", mainTsv).
		writeFile("group.tsv", groupTsv).
		writeFile("linker.tsv", linkerTsv).
		writeFile("linkerAlt.tsv", linkerAltTsv).
		writeFile("region.tsv", regionTsv).
		writeFile("linker2.tsv", linker2Tsv).
		writeFile("nameLabel.tsv", nameLabelTsv).
		writeFile("groupLabel.tsv", groupLabelTsv).
		writeFile("regionLabel.tsv", regionLabelTsv).
		saveFile("main.tsv").
		saveFile("group.tsv").
		saveFile("linker.tsv").
		saveFile("linkerAlt.tsv").
		saveFile("region.tsv").
		saveFile("linker2.tsv").
		saveFile("nameLabel.tsv").
		saveFile("groupLabel.tsv").
		saveFile("regionLabel.tsv").
		run()

	mainFile := e.getFile("main.tsv")
	groupFile := e.getFile("group.tsv")
	linkerFile := e.getFile("linker.tsv")
	linkerAltFile := e.getFile("linkerAlt.tsv")
	regionFile := e.getFile("region.tsv")
	linker2File := e.getFile("linker2.tsv")
	nameLabelFile := e.getFile("nameLabel.tsv")
	groupLabelFile := e.getFile("groupLabel.tsv")
	regionLabelFile := e.getFile("regionLabel.tsv")

	nameAxisSpec := {
		name: "name",
		type: "String",
		annotations: {
			"pl7.app/label": "Name"
		}
	}

	nameAxisSpecPrimary := {
		name: "name",
		type: "String",
		annotations: {
			"pl7.app/label": "Name"
		},
		domain: {
			"pl7.app/source": "primary"
		}
	}

	nameAxisSpecSecondary := {
		name: "name",
		type: "String",
		annotations: {
			"pl7.app/label": "Name"
		},
		domain: {
			"pl7.app/source": "secondary"
		}
	}

	groupAxisSpec := {
		name: "group",
		type: "String",
		annotations: {
			"pl7.app/label": "Group"
		}
	}

	groupAxisSpecHit := {
		name: "group",
		type: "String",
		annotations: {
			"pl7.app/label": "Group hit"
		},
		parentAxes: [0]
	}

	groupAxisSpecPrimary := {
		name: "group",
		type: "String",
		annotations: {
			"pl7.app/label": "Group primary"
		},
		domain: {
			"pl7.app/source": "primary"
		},
		parentAxes: [0]
	}

	groupAxisSpecSecondary := {
		name: "group",
		type: "String",
		annotations: {
			"pl7.app/label": "Group secondary"
		},
		domain: {
			"pl7.app/source": "secondary"
		},
		parentAxes: [0]
	}

	regionAxisSpec := {
		name: "region",
		type: "String",
		annotations: {
			"pl7.app/label": "Region"
		}
	}

	mainSpec := {
		axes: [{
			column: "name",
			spec: nameAxisSpec
		}],
		columns: [{
			column: "value",
			id: "value",
			spec: {
				name: "value",
				valueType: "Int",
				annotations: {
					"pl7.app/label": "Value"
				}
			}
		}, {
			column: "score",
			id: "score",
			spec: {
				name: "score",
				valueType: "Double",
				annotations: {
					"pl7.app/label": "Score"
				}
			}
		}, {
			column: "category",
			id: "category",
			spec: {
				name: "category",
				valueType: "String",
				annotations: {
					"pl7.app/label": "Category"
				}
			}
		}, {
			column: "note",
			id: "note",
			spec: {
				name: "note",
				valueType: "String",
				annotations: {
					"pl7.app/label": "Note"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	groupSpec := {
		axes: [{
			column: "group",
			spec: groupAxisSpec
		}, {
			column: "group",
			spec: groupAxisSpecHit
		}],
		columns: [{
			column: "description",
			id: "description",
			spec: {
				name: "description",
				valueType: "String",
				annotations: {
					"pl7.app/label": "Description"
				}
			}
		}, {
			column: "priority",
			id: "priority",
			spec: {
				name: "priority",
				valueType: "Int",
				annotations: {
					"pl7.app/label": "Priority"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	// Linker A: group axis domain=source:primary. Carries rows A,B,C only.
	linkerSpec := {
		axes: [{
			column: "group",
			spec: groupAxisSpec
		}, {
			column: "group",
			spec: groupAxisSpecPrimary
		}, {
			column: "group",
			spec: groupAxisSpecSecondary
		}, {
			column: "name",
			spec: nameAxisSpec
		}],
		columns: [{
			column: "link",
			id: "linker_name_group",
			spec: {
				name: "linker_name_group",
				valueType: "Int",
				annotations: {
					"pl7.app/linkLabel": "Name-Group Linker (primary)",
					"pl7.app/isLinkerColumn": "true"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	// Linker B: group axis domain=source:secondary. Carries rows C,D,E only.
	// Same (name, group) axis pair as linker A by name/type but with a distinct
	// axis `domain` — discoverColumns emits a MatchVariant whose hit-axis
	// qualification carries contextDomain={pl7.app/source: secondary}, which
	// differs from linker A's variant. That delta populates
	// `distinctiveQualifications.forHit` on both variants.
	linkerAltSpec := {
		axes: [{
			column: "group",
			spec: groupAxisSpec
		}, {
			column: "name",
			spec: nameAxisSpec
		}],
		columns: [{
			column: "linkAlt",
			id: "linker_name_group_alt",
			spec: {
				name: "linker_name_group_alt",
				valueType: "Int",
				annotations: {
					"pl7.app/linkLabel": "Name-Group Linker (secondary)",
					"pl7.app/isLinkerColumn": "true"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	regionSpec := {
		axes: [{
			column: "region",
			spec: regionAxisSpec
		}],
		columns: [{
			column: "regionName",
			id: "regionName",
			spec: {
				name: "regionName",
				valueType: "String",
				annotations: {
					"pl7.app/label": "Region Name"
				}
			}
		}, {
			column: "population",
			id: "population",
			spec: {
				name: "population",
				valueType: "Int",
				annotations: {
					"pl7.app/label": "Population"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	linker2Spec := {
		axes: [{
			column: "region",
			spec: regionAxisSpec
		}, {
			column: "group",
			spec: groupAxisSpec
		}],
		columns: [{
			column: "link2",
			id: "linker_group_region",
			spec: {
				name: "linker_group_region",
				valueType: "Int",
				annotations: {
					"pl7.app/linkLabel": "Group-Region Linker",
					"pl7.app/isLinkerColumn": "true"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	nameLabelSpec := {
		axes: [{
			column: "name",
			spec: nameAxisSpec
		}],
		columns: [{
			column: "label",
			id: "nameLabel",
			spec: {
				name: "pl7.app/label",
				valueType: "String",
				annotations: {
					"pl7.app/label": "Name label"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	groupLabelSpec := {
		axes: [{
			column: "group",
			spec: groupAxisSpec
		}],
		columns: [{
			column: "label",
			id: "groupLabel",
			spec: {
				name: "pl7.app/label",
				valueType: "String",
				annotations: {
					"pl7.app/label": "Group label"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	regionLabelSpec := {
		axes: [{
			column: "region",
			spec: regionAxisSpec
		}],
		columns: [{
			column: "label",
			id: "regionLabel",
			spec: {
				name: "pl7.app/label",
				valueType: "String",
				annotations: {
					"pl7.app/label": "Region label"
				}
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	}

	importOps := { inputCache: times.second, splitDataAndSpec: true }
	mainPf := xsv.importFile(mainFile, "tsv", mainSpec, importOps)
	groupPf := xsv.importFile(groupFile, "tsv", groupSpec, importOps)
	linkerPf := xsv.importFile(linkerFile, "tsv", linkerSpec, importOps)
	linkerAltPf := xsv.importFile(linkerAltFile, "tsv", linkerAltSpec, importOps)
	regionPf := xsv.importFile(regionFile, "tsv", regionSpec, importOps)
	linker2Pf := xsv.importFile(linker2File, "tsv", linker2Spec, importOps)
	nameLabelPf := xsv.importFile(nameLabelFile, "tsv", nameLabelSpec, importOps)
	groupLabelPf := xsv.importFile(groupLabelFile, "tsv", groupLabelSpec, importOps)
	regionLabelPf := xsv.importFile(regionLabelFile, "tsv", regionLabelSpec, importOps)

	// Republish every column as a block export so downstream blocks
	// can discover the linker chain through the result pool.
	pf := pframes.pFrameBuilder()
	addAll := func(...srcPfs) {
		for srcPf in srcPfs {
			for k, v in srcPf {
				pf.add(k, v.spec, v.data)
			}
		}
	}
	addAll(mainPf, groupPf, linkerPf, linkerAltPf, regionPf, linker2Pf,
		nameLabelPf, groupLabelPf, regionLabelPf)
	pf = pf.build()

	return {
		outputs: {
			tableFrame: pframes.exportFrame(pf)
		},
		exports: {
			tableFrame: pf
		}
	}
})
