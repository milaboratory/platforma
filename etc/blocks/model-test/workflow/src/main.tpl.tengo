wf := import("@platforma-sdk/workflow-tengo:workflow")
exec := import("@platforma-sdk/workflow-tengo:exec")
assets := import("@platforma-sdk/workflow-tengo:assets")
xsv := import("@platforma-sdk/workflow-tengo:pframes.xsv")
pframes := import("@platforma-sdk/workflow-tengo:pframes")

wf.body(func(args) {
	readLogsSW := assets.importSoftware("@platforma-open/milaboratories.software-test-utils:read-file-to-stdout-with-sleep")

	run := exec.builder().
		cpu(1).ram("50Mi").
		software(readLogsSW).
		writeFile("file.txt", "a\nb\nc\n" + args.titleArg + "\n" + args.subtitleArg + "\n").
		arg("file.txt").
		arg("progress").
		arg("1000").
		arg("500")

	result := run.saveStdoutContent().run()

	// Simple PFrame with one axis and one column for createPlDataTable test
	tsvContent := "item\tscore\nAlpha\t10\nBeta\t20\nGamma\t30"
	tsvFile := exec.builder().
		cpu(1).ram("50Mi").
		cmd("cat").
		writeFile("data.tsv", tsvContent).
		saveFile("data.tsv").
		run().
		getFile("data.tsv")

	pf := xsv.importFile(tsvFile, "tsv", {
		axes: [{
			column: "item",
			spec: {
				name: "item",
				type: "String"
			}
		}],
		columns: [{
			column: "score",
			id: "score",
			spec: {
				name: "mock_score",
				valueType: "Int"
			}
		}],
		storageFormat: "Binary",
		partitionKeyLength: 0
	})

	return {
		outputs: {
			theOutput: args.tagToWorkflow,
			delayedContent: result.getStdoutContent(),
			tableFrame: pframes.exportFrame(pf)
		},
		exports: {}
	}
})
