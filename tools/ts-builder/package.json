{
  "name": "@milaboratories/ts-builder",
  "version": "1.2.13",
  "description": "TS build tool for the milaboratories packages",
  "bin": {
    "ts-builder": "./bin/ts-builder.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    "./configs/*": "./dist/configs/*"
  },
  "scripts": {
    "build": "rolldown -c",
    "watch": "rolldown -c --watch",
    "do-pack": "rm -f *.tgz && pnpm pack && mv *.tgz package.tgz",
    "check": "oxlint && oxfmt --check && tsc --noEmit",
    "fmt": "oxlint --fix && oxfmt"
  },
  "dependencies": {
    "@milaboratories/ts-configs": "workspace:*",
    "@vitejs/plugin-vue": "catalog:",
    "commander": "^12.0.0",
    "jsonc-parser": "catalog:",
    "oxfmt": "0.35.0",
    "oxlint": "1.43.0",
    "rolldown": "^1.0.0-rc.5",
    "rolldown-plugin-dts": "^0.22.1",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-sourcemaps2": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-plugin-externalize-deps": "catalog:",
    "vite-plugin-lib-inject-css": "catalog:",
    "vue-tsc": "catalog:"
  }
}
