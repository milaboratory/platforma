{
  "name": "@platforma-sdk/pl-cli",
  "version": "0.8.1",
  "description": "CLI for Platforma server state manipulation",
  "license": "UNLICENSED",
  "bin": {
    "pl-cli": "./bin/run.mjs"
  },
  "files": [
    "./bin/*",
    "./dist/**/*",
    "./src/**/*",
    "./README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "do-pack": "rm -f *.tgz && pnpm pack && mv *.tgz package.tgz",
    "check": "ts-builder check --target node",
    "formatter:check": "ts-builder formatter --check",
    "linter:check": "ts-builder linter --check",
    "types:check": "ts-builder type-check --target node",
    "fmt": "ts-builder format"
  },
  "dependencies": {
    "@milaboratories/pl-client": "workspace:*",
    "@milaboratories/pl-middle-layer": "workspace:*",
    "commander": "catalog:"
  },
  "devDependencies": {
    "@milaboratories/build-configs": "workspace:*",
    "@milaboratories/ts-builder": "workspace:*",
    "@milaboratories/ts-configs": "workspace:*",
    "@types/node": "catalog:",
    "rollup-plugin-node-externals": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  }
}
