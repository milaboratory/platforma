{
  "name": "@platforma-sdk/blocks-deps-updater",
  "version": "2.2.0",
  "description": "Update dependencies in pnpm workspace catalog",
  "license": "UNLICENSED",
  "bin": {
    "pl-blocks-deps-updater": "./bin/run.mjs"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate-pinned": "node scripts/generate-pinned.mjs",
    "build": "pnpm generate-pinned && ts-builder build --target node",
    "test": "vitest run",
    "check": "ts-builder check --target node",
    "formatter:check": "ts-builder formatter --check",
    "linter:check": "ts-builder linter --check",
    "types:check": "pnpm generate-pinned && ts-builder type-check --target node",
    "fmt": "ts-builder format",
    "do-pack": "rm -f *.tgz && pnpm pack && mv *.tgz package.tgz"
  },
  "dependencies": {
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@milaboratories/ts-builder": "workspace:*",
    "@milaboratories/ts-configs": "workspace:*",
    "@types/node": "catalog:",
    "dedent": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
