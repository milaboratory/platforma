// Integration-test template for the wasm subsystem.
//
// Flow:
//   1. tengo-builder sees `assets.importWasm(...)` and bundles the
//      `@platforma-tests/wasm-table-fixture` component into this template's
//      pack.
//   2. At runtime, `plapi.loadWasm("@platforma-tests/wasm-table-fixture:main")` returns a sandboxed
//      component handle.
//   3. We exercise the WIT methods on the `demo:tables/api` interface:
//      `from-json` (returns a resource), `find-column` (string -> result<string,string>).
//   4. Both happy path and the result.Err arm get exercised — outputs are
//      always plain strings (never undefined) so the SDK doesn't reject them.

self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")
plapi := import("plapi")
json := import("json")

assets.importWasm("@platforma-tests/wasm-table-fixture:main")

self.defineOutputs(["ok", "err", "trap"])

self.body(func(_inputs) {
	c := plapi.loadWasm("@platforma-tests/wasm-table-fixture:main")
	if is_error(c) {
		msg := "loadWasm failed: " + string(c)
		return { ok: msg, err: msg, trap: msg }
	}

	api := c.exports["demo:tables/api"]

	// json.encode returns bytes; the wasm boundary expects a string,
	// so wrap each encode call with string(...).
	tableSpec := string(json.encode({
		columns: [
			{ name: "sample_id", type: "i32" },
			{ name: "barcode",   type: "string" }
		]
	}))

	frame := api.table.fromJson(tableSpec)
	if is_error(frame) {
		msg := "from-json failed: " + string(frame)
		return { ok: msg, err: msg, trap: msg }
	}

	// Happy path: existing column.
	okSel := string(json.encode({ name: "sample_id" }))
	okResp := frame.findColumn(okSel)

	// Err arm: missing column → result.Err arm → Tengo error.
	errSel := string(json.encode({ name: "no_such_col" }))
	errResp := frame.findColumn(errSel)

	// Trap arm: the fixture's always_panic traps the guest. The bridge
	// surfaces the trap as a Tengo error; the instance is poisoned after
	// (we don't reuse it here, but the production runtime does that
	// check elsewhere).
	trapResp := api.table.alwaysPanic("integration-test trap")

	return {
		ok:   string(okResp),
		err:  string(errResp),
		trap: string(trapResp)
	}
})
