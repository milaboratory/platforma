// Malformed-input probe. The fixture's fromJson parses its string arg
// as JSON inside the guest. When the host passes garbage, the guest's
// serde_json returns the result.Err arm; the bridge aborts the script.
//
// Single template parametrised by inputs.badInput (passed in as a
// JsonObject value resource by the test). Each .test.ts case sends a
// different bad input and asserts the render aborts with a guest error
// message — split so a regression in one case (e.g. one of the bad
// inputs accidentally trapping instead of returning Err) doesn't
// shadow the other cases.

self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")

self.awaitState("InputsLocked")
self.awaitState("badInput", "ResourceReady")

self.defineOutputs(["unreachable"])

self.body(func(inputs) {
	api := assets.importWasm("@platforma-tests/wasm-table-fixture:main")["demo:tables/api"]
	api.table.fromJson(inputs.badInput)
	return { unreachable: "reached end of body v2" }
})
