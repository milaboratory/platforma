// Per-render Store-budget probe. The backend caps a single render at
// MaxWasmStoresPerRender = 64 sandboxed instances. Calling importWasm 65
// times aborts the script on the 65th call with a clear cap-mentioning
// error — same family-wide pattern as importSoftware / importAsset /
// importTemplate (unrecoverable load failures abort the script).
//
// The .test.ts side asserts the render fails (via expect().rejects);
// this template just runs the loop so the 65th iteration triggers the
// abort.

self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")

self.defineOutputs(["unreachable"])

self.body(func(_inputs) {
	for i := 0; i < 65; i++ {
		assets.importWasm("@platforma-tests/wasm-table-fixture:main")
	}
	// The 65th call above must abort the script; this return is
	// unreachable. If the cap is silently raised and we reach here, the
	// test sees the "unreachable" output instead of the expected render
	// failure.
	return { unreachable: "reached end of loop without aborting" }
})
