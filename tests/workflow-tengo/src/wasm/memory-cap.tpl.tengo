// Below-cap probes. The live per-instance cap on this template is the
// backend's default = 32 MiB (we don't override DefaultMemoryLimit on
// the WasmV1 dep). Both 8 MiB and 24 MiB are comfortably below the cap;
// consumeMemory returns its "consumed N bytes" ack on success.
//
// Over-cap probes have their own templates (memory-cap-overflow-near,
// memory-cap-overflow-far) because any allocation that exceeds the cap
// traps inside the guest and aborts the script — they can't share a
// render with the below-cap assertions.

self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")

self.defineOutputs(["wellBelow", "nearBelow"])

probe := func(bytes) {
	api := assets.importWasm("@platforma-tests/wasm-table-fixture:main")["demo:tables/api"]
	// Argument is a decimal string — see the WIT comment on
	// `consume-memory` for the host's current arg-lowering limitation.
	return string(api.table.consumeMemory(string(bytes)))
}

self.body(func(_inputs) {
	mib := 1024 * 1024
	return {
		wellBelow: probe(8 * mib),
		nearBelow: probe(24 * mib)
	}
})
