// Verifies that two sibling instances produced by separate assets.importWasm
// calls inside one render hold independent state. If the host accidentally
// shared a Store between the two handles, instance B's columnCount would
// reflect A's columns or vice versa.
//
// Instance A has 5 distinct columns; instance B has 1 column with a name
// that doesn't appear in A. Both columnCount and findColumn responses are
// captured so we assert by data, not just by count.

self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")
json := import("json")

self.defineOutputs([
	"countA", "countB",
	"aFindFromA", "aFindFromB",
	"bFindFromA", "bFindFromB"
])

self.body(func(_inputs) {
	specA := string(json.encode({
		columns: [
			{ name: "alpha",   type: "i32" },
			{ name: "bravo",   type: "i32" },
			{ name: "charlie", type: "i32" },
			{ name: "delta",   type: "i32" },
			{ name: "echo",    type: "i32" }
		]
	}))
	specB := string(json.encode({
		columns: [
			{ name: "only-in-b", type: "string" }
		]
	}))

	wasmA := assets.importWasm("@platforma-tests/wasm-table-fixture:main")
	wasmB := assets.importWasm("@platforma-tests/wasm-table-fixture:main")

	apiA := wasmA.exports["demo:tables/api"]
	apiB := wasmB.exports["demo:tables/api"]

	tableA := apiA.table.fromJson(specA)
	tableB := apiB.table.fromJson(specB)

	// columnCount must reflect each instance's own state. Wrap in string()
	// so every output is a JSON-string resource — uniform shape across outputs.
	countA := string(tableA.columnCount())
	countB := string(tableB.columnCount())

	selA := string(json.encode({ name: "alpha" }))
	selB := string(json.encode({ name: "only-in-b" }))

	// Cross-probe: searching for A's column in B must miss, and vice versa.
	aFindFromA := string(tableA.findColumn(selA))
	aFindFromB := string(tableB.findColumn(selA))
	bFindFromA := string(tableA.findColumn(selB))
	bFindFromB := string(tableB.findColumn(selB))

	return {
		countA:     countA,
		countB:     countB,
		aFindFromA: aFindFromA,
		aFindFromB: aFindFromB,
		bFindFromA: bFindFromA,
		bFindFromB: bFindFromB
	}
})
