// Runaway-guest variant of the epoch-deadline probe. Calls spinMillis
// with a duration guaranteed to exceed the backend's per-call wasm
// budget AND the interpreter's MaxExecutionTime (both default to 1
// minute). Exactly which layer fires first is a backend-internal race
// we don't need to nail down — either way the render aborts.

self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")
times := import("times")

self.defineOutputs(["unreachable"])

self.body(func(_inputs) {
	api := assets.importWasm("@platforma-tests/wasm-table-fixture:main")["demo:tables/api"]
	api.table.spinMillis("90000")
	return { unreachable: "reached end of body v3" + times.now() }
})
