/**
 * Exercises resource formulas (memFormula / cpuFormula) end-to-end.
 *
 * The input file is added with tag "reads". The mem/cpu formulas are built from
 * the DSL (exec.formula) according to inputs.mode. The command is the test-utils
 * hello-world software, which echoes its argument back to stdout — with the
 * backend substituting {system.ram.bytes} and {system.cpu} for the ACTUALLY
 * ALLOCATED quota. The test reads stdout to learn what the runner allocated and
 * compares it against the formula's expected value.
 *
 * (Mirrors echo_ui_queue_limits.tpl.tengo, which is the established pattern for
 * observing an exec's allocated cpu/ram; a bare cmd without .software() does not
 * run on the runner.)
 */
self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")
ll := import("@platforma-sdk/workflow-tengo:ll")
exec := import("@platforma-sdk/workflow-tengo:exec")
file := import("@platforma-sdk/workflow-tengo:file")

f := exec.formula

self.defineOutputs(["limits"])

sw := assets.importSoftware("@platforma-open/milaboratories.software-test-utils:hello-world")

self.body(func(inputs) {
	inputFile := file.importFile(inputs.file).file

	mode := inputs.mode

	memAst := undefined
	cpuAst := undefined
	if mode == "size" {
		// 1 GiB + size("reads") bytes ; 2 + 1 = 3 cores
		memAst = f.add(f.gib(1), f.size("reads"))
		cpuAst = f.add(2, 1)
	} else if mode == "lineCount" {
		// 512 MiB + lineCount("reads") * 1024 bytes ; 1 + 1 = 2 cores
		memAst = f.add(f.mib(512), f.mul(f.lineCount("reads"), 1024))
		cpuAst = f.add(1, 1)
	} else {
		ll.panic("formula_limits: unknown mode %v", mode)
	}

	// Heavy queue (large default cpu/ram cap) leaves headroom so a ~1 GiB /
	// few-core formula request is not capped by the queue limit.
	// `mode` is appended to the echoed arg so the two modes produce CID-distinct
	// execs: formula meta inputs are CID-transparent, so size-mode and
	// lineCount-mode would otherwise dedup to one run (and one allocation).
	run := exec.builder().
		inHeavyQueue().
		software(sw).
		argWithVar("{system.ram.bytes},{system.cpu}," + mode).
		addFile("input.txt", inputFile, { tag: "reads" }).
		memFormula(memAst).
		cpuFormula(cpuAst).
		saveStdoutContent().
		run()

	return {
		limits: run.getStdoutContent()
	}
})
