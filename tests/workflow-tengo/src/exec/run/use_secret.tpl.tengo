/** Runs a cat on the file and returns it's content as a value resource. */

self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")
smart := import("@platforma-sdk/workflow-tengo:smart")
exec := import("@platforma-sdk/workflow-tengo:exec")
file := import("@platforma-sdk/workflow-tengo:file")

self.defineOutputs(["customEnv", "defaultEnv"])

self.body(func(inputs) {
	customEnv := exec.builder().
		cpu(1).ram("1Mi").
		secret("MI_LICENSE", "SECRET_ENV").
		cmd("bash").
		arg("-c").
		arg("echo $SECRET_ENV").
		inLightQueue().
		saveStdoutContent().
		run()

	defaultEnv := exec.builder().
		cpu(1).ram("1Mi").
		secret("MI_LICENSE").
		cmd("bash").
		arg("-c").
		arg("echo $MI_LICENSE").
		inLightQueue().
		saveStdoutContent().
		run()

	result := {
		customEnv: customEnv.getStdoutContent(),
		defaultEnv: defaultEnv.getStdoutContent()
	}

	return result
})
