/**
 * End-to-end check for zstd-compressed lineCount input.
 *
 * The input is a zstd fixture, added under a ".zst" name. Two things must line
 * up for the count to be right: the SDK must strip the .zst suffix to accept
 * lineCount (formula.lib compression handling), and the line-counter binary must
 * DECOMPRESS it before counting (>= 1.1.1; software-small-binaries >= 2.1.1).
 * Only .gz was proven end-to-end before — this closes the zstd codec gap.
 *
 * The ",zst" arg suffix keeps this exec CID-distinct from the other formula
 * templates (formula meta inputs are CID-transparent).
 *
 * memFormula = 512 MiB + lineCount("reads")*1024 ; cpuFormula = 1 + 1 = 2.
 */
self := import("@platforma-sdk/workflow-tengo:tpl")
assets := import("@platforma-sdk/workflow-tengo:assets")
exec := import("@platforma-sdk/workflow-tengo:exec")
file := import("@platforma-sdk/workflow-tengo:file")

f := exec.formula

self.defineOutputs(["limits"])

sw := assets.importSoftware("@platforma-open/milaboratories.software-test-utils:hello-world")

self.body(func(inputs) {
	inputFile := file.importFile(inputs.file).file

	run := exec.builder().
		inHeavyQueue().
		software(sw).
		argWithVar("{system.ram.bytes},{system.cpu},zst").
		addFile("reads.fastq.zst", inputFile, { tag: "reads" }).
		memFormula(f.add(f.mib(512), f.mul(f.lineCount("reads"), 1024))).
		cpuFormula(f.add(1, 1)).
		saveStdoutContent().
		run()

	return {
		limits: run.getStdoutContent()
	}
})
