self := import("@platforma-sdk/workflow-tengo:tpl")
exec := import("@platforma-sdk/workflow-tengo:exec")

self.defineOutputs(["cpu", "ram"])

self.body(func(inputs) {
	cpuRun := exec.builder().
		inUiQueue().
		cmd("/usr/bin/env").
		arg("bash").
		arg("-c").
		argWithVar("echo -n {system.cpu}").
		saveStdoutContent().
		run()

	ramRun := exec.builder().
		inUiQueue().
		cmd("/usr/bin/env").
		arg("bash").
		arg("-c").
		argWithVar("echo -n {system.ram.bytes}").
		saveStdoutContent().
		run()

	return {
		cpu: cpuRun.getStdoutContent(),
		ram: ramRun.getStdoutContent()
	}
})
