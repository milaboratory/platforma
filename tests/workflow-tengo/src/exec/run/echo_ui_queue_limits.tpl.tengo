self := import("@platforma-sdk/workflow-tengo:tpl")
exec := import("@platforma-sdk/workflow-tengo:exec")

self.defineOutputs(["limits"])

self.body(func(inputs) {
	limitsRun := exec.builder().
		inUiQueue().
		cmd("/usr/bin/env").
		arg("bash").
		arg("-c").
		argWithVar("echo -n {system.cpu},{system.ram.bytes}").
		saveStdoutContent().
		run()

	return {
		limits: limitsRun.getStdoutContent()
	}
})
