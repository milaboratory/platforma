// Parameterized query template for contextDomain filter tests.
// All query parameters are passed via args.query.
//
// Inputs:
//   args.query    — column selector passed to anchoredQuery (name, contextDomain, axes, etc.)
//   args.specOnly — (optional, default true) whether to fetch spec only
//   args.rawOnly  — (optional, default false) output only r1 (raw result), skip r1Spec
//                   Use for single-result no-match tests where spec field doesn't exist.
//
// Outputs:
//   r1     — raw query result (RTYPE_QUERY_RESULT), always present
//   r1Spec — spec field of the query result; omitted when rawOnly is true

wf := import("@platforma-sdk/workflow-tengo:workflow")

wf.body(func(args) {
	specOnly := is_undefined(args.specOnly) ? true : args.specOnly
	rawOnly := !is_undefined(args.rawOnly) && args.rawOnly

	qResult := wf.anchoredQuery({}, {
		r1: {
			query: args.query,
			specOnly: specOnly
		}
	})

	outputs := {
		r1: qResult.getResult("r1")
	}
	if !rawOnly {
		outputs["r1Spec"] = qResult.getResultSpec("r1")
	}

	return {
		outputs: outputs,
		exports: {}
	}
})
