{
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "PL_PKG_VERSION",
        "PL_PKG_FULL_HASH",
        "PL_DOCKER_REGISTRY",
        "PL_BUILD_CHANNEL",
        "PL_BUILD_VARIANT",
        "PL_BUILD_LOCATION",
        "PL_BUILD_USE_PUBLISHED",
        "PL_DEV_DOCKER_PUSH_URL",
        "PL_DEV_DOCKER_PULL_URL",
        "PL_DEV_BINARY_UPLOAD_URL",
        "PL_RELEASE_DOCKER_PUSH_URL",
        "PL_RELEASE_DOCKER_PULL_URL",
        "PL_RELEASE_BINARY_UPLOAD_URL",
        "PL_REGISTRY_PLATFORMA_OPEN_UPLOAD_URL"
      ],
      "passThroughEnv": [
        "AWS_*",
        "PL_AWS_*",
        "PL_DOCKER_REGISTRY_PUSH_TO",
        "PL_DOCKER_BUILD",
        "PL_DOCKER_NO_BUILD",
        "PL_DOCKER_AUTOPUSH",
        "PL_DOCKER_NO_AUTOPUSH"
      ]
    },
    "do-pack": {
      "env": [
        "PL_PKG_VERSION",
        "PL_PKG_FULL_HASH",
        "PL_DOCKER_REGISTRY",
        "PL_BUILD_CHANNEL",
        "PL_BUILD_VARIANT",
        "PL_BUILD_LOCATION",
        "PL_BUILD_USE_PUBLISHED",
        "PL_DEV_DOCKER_PUSH_URL",
        "PL_DEV_DOCKER_PULL_URL",
        "PL_DEV_BINARY_UPLOAD_URL",
        "PL_RELEASE_DOCKER_PUSH_URL",
        "PL_RELEASE_DOCKER_PULL_URL",
        "PL_RELEASE_BINARY_UPLOAD_URL",
        "PL_REGISTRY_PLATFORMA_OPEN_UPLOAD_URL"
      ],
      "passThroughEnv": [
        "AWS_*",
        "PL_AWS_*",
        "PL_DOCKER_REGISTRY_PUSH_TO",
        "PL_DOCKER_BUILD",
        "PL_DOCKER_NO_BUILD",
        "PL_DOCKER_AUTOPUSH",
        "PL_DOCKER_NO_AUTOPUSH"
      ]
    }
  }
}
