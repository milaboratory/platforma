test := import(":test")
metricProvider := import(":exec.metric-provider")
execMetrics := import(":exec.metrics")

// Provider slot is empty until set() is called.
TestMetricProviderNotSetBeforeSet := func() {
	// A fresh import of :exec.metric-provider has no provider registered.
	freshProvider := import(":exec.metric-provider")
	test.isFalse(freshProvider.isSet(), "provider should not be set before calling set()")
}

// set()/get()/isSet() form a correct read-write cycle within one import chain.
TestMetricProviderSetGetCycle := func() {
	mp := import(":exec.metric-provider")
	test.isFalse(mp.isSet(), "provider should not be set initially")
	fakeProvider := {
		lineCountResource: func(ref, name) { return undefined },
		aggregateMetricMap: func(perFile) { return undefined }
	}
	mp.set(fakeProvider)
	test.isTrue(mp.isSet(), "provider should be set after set()")
	got := mp.get()
	test.isTrue(!is_undefined(got.lineCountResource), "retrieved provider exposes lineCountResource")
	test.isTrue(!is_undefined(got.aggregateMetricMap), "retrieved provider exposes aggregateMetricMap")
}

// :exec.metrics exports the two functions required by the exec builder.
TestExecMetricsExportsRequiredFunctions := func() {
	test.isTrue(!is_undefined(execMetrics.lineCountResource), "exec.metrics exports lineCountResource")
	test.isTrue(!is_undefined(execMetrics.aggregateMetricMap), "exec.metrics exports aggregateMetricMap")
}
