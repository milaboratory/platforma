test := import(":test")
exec := import(":exec")

test.run("Test_gpu_no_args", func() {
	b := exec.builder().gpu()
	test.assert(b != undefined, "gpu() should return builder")
	// Verify it's still chainable
	b2 := b.arg("--flag")
	test.assert(b2 != undefined, "should be chainable after gpu()")
})

test.run("Test_gpu_with_size_string", func() {
	b := exec.builder().gpu("16GiB")
	test.assert(b != undefined, "gpu('16GiB') should return builder")
})

test.run("Test_gpu_chaining", func() {
	b := exec.builder().gpu("4GiB").arg("--flag")
	test.assert(b != undefined, "chaining after gpu() should work")
})
