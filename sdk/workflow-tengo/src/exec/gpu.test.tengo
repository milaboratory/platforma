test := import(":test")
exec := import(":exec")
ll := import(":ll")

Test_gpu_no_args := func() {
	b := exec.builder().
		cmd("test").
		cpu(1).
		mem("2GiB").
		gpuMemory()

	test.isTrue(ll.methodExists(b, "run"), "gpuMemory() should return builder with run method")
}

Test_gpu_with_size_string := func() {
	b := exec.builder().
		cmd("test").
		cpu(1).
		mem("2GiB").
		gpuMemory("16GiB")

	test.isTrue(ll.methodExists(b, "run"), "gpuMemory('16GiB') should return builder with run method")
}

Test_gpu_chaining := func() {
	b := exec.builder().
		cmd("test").
		cpu(1).
		mem("2GiB").
		gpuMemory("4GiB").
		arg("--flag")

	test.isTrue(ll.methodExists(b, "run"), "gpuMemory() should not break the builder chain")
}

Test_gpu_override := func() {
	b := exec.builder().
		cmd("test").
		cpu(1).
		mem("2GiB").
		gpuMemory("2GiB").
		gpuMemory("16GiB")

	test.isTrue(ll.methodExists(b, "run"), "gpuMemory() override should return valid builder")
}
