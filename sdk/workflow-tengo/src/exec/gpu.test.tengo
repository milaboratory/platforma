test := import(":test")
exec := import(":exec")
ll := import(":ll")

Test_gpu_method_exists := func() {
	b := exec.builder()
	test.isTrue(ll.methodExists(b, "gpu"), "exec.builder should have gpu method")
}

Test_gpu_with_count_only := func() {
	b := exec.builder().
		cmd("nvidia-smi").
		cpu(1).
		mem("2GiB").
		gpu(1)

	// builder should return self for chaining
	test.isTrue(ll.methodExists(b, "run"), "gpu() should return builder with run method")
}

Test_gpu_with_count_and_type := func() {
	b := exec.builder().
		cmd("nvidia-smi").
		cpu(1).
		mem("2GiB").
		gpu(2, "nvidia-tesla-a100")

	test.isTrue(ll.methodExists(b, "run"), "gpu(count, type) should return builder")
}

Test_gpu_chaining := func() {
	b := exec.builder().
		cmd("test").
		cpu(1).
		mem("2GiB").
		gpu(4, "a100").
		arg("--flag")

	test.isTrue(ll.methodExists(b, "run"), "gpu() should not break the builder chain")
}

Test_gpu_count_only_no_type := func() {
	b := exec.builder().
		cmd("test").
		cpu(1).
		mem("2GiB").
		gpu(1)

	test.isTrue(ll.methodExists(b, "gpu"), "builder still has gpu method after calling it")
}
