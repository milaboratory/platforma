/** A pure template that gets a resource's data of monetization as bytes,
 * parses a json that it gets and returns each field
 * as outputs. */

self := import(":tpl")
json := import("json")
text := import("text")

self.defineOutputs("jwtToken", "nRemainingRuns")

self.body(func(inputs) {
	data := inputs.resource.getData()
	decoded := json.decode(data)

	return {
		jwtToken: decoded.jwtToken,
		nRemainingRuns: decoded.nRemainingRuns
	}
})
