test := import(":test")
times := import("times")
tb := import(":pframes.table-builder")

sampleSpec := { kind: "PColumn", name: "test", valueType: "Int", axesSpec: [{ name: "id", type: "String" }] }
sampleRef := { __isRef: true, blockId: "b1", name: "e1" }
sampleResolved := { spec: sampleSpec, data: "data_ref" }
samplePrimaryRef := {
	__isPrimaryRef: "v1",
	column: sampleRef
}
sampleResolvedPrimary := {
	__isPrimaryRef: "v1",
	column: sampleResolved,
	filter: { spec: sampleSpec, data: "filter_data" }
}

TestTableBuilderReturnsBuilder := func() {
	b := tb.tableBuilder("tsv")
	test.isTrue(!is_undefined(b.addPrimary), "should have addPrimary")
	test.isTrue(!is_undefined(b.addColumn), "should have addColumn")
	test.isTrue(!is_undefined(b.addColumns), "should have addColumns")
	test.isTrue(!is_undefined(b.build), "should have build")
	test.isTrue(!is_undefined(b.setJoinMode), "should have setJoinMode")
	test.isTrue(!is_undefined(b.setAxisHeader), "should have setAxisHeader")
	test.isTrue(!is_undefined(b.cpu), "should have cpu")
	test.isTrue(!is_undefined(b.mem), "should have mem")
	test.isTrue(!is_undefined(b.cacheInputs), "should have cacheInputs")
}

TestAllFormatsAccepted := func() {
	tb.tableBuilder("tsv")
	tb.tableBuilder("csv")
	tb.tableBuilder("parquet")
	tb.tableBuilder("ndjson")
	test.isTrue(true, "all formats accepted")
}

TestChainingWorks := func() {
	b := tb.tableBuilder("tsv")
	result := b.addPrimary("main", sampleResolved).
		addColumn(sampleResolved, { header: "Col1" }).
		addColumns(sampleResolved).
		setJoinMode("full").
		setAxisHeader("id", "ID").
		cpu(4).
		mem("16GiB").
		cacheInputs(1 * times.minute)
	test.isTrue(!is_undefined(result.build), "chaining should return builder")
}

TestDetectsUnresolvedPlRef := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleRef)
	test.isTrue(true, "addPrimary accepts unresolved PlRef")
}

TestDetectsResolvedColumn := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved)
	test.isTrue(true, "addPrimary accepts resolved column")
}

TestDetectsPrimaryRef := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", samplePrimaryRef)
	test.isTrue(true, "addPrimary accepts PrimaryRef")
}

TestDetectsResolvedPrimaryRef := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolvedPrimary)
	test.isTrue(true, "addPrimary accepts resolved PrimaryRef")
}

TestAddColumnDetectsResolved := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved)
	b.addColumn(sampleResolved, { header: "Test" })
	test.isTrue(true, "addColumn accepts resolved column")
}

TestAddColumnDetectsQuerySpec := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved)
	b.addColumn({ axes: [{ anchor: "main", name: "pl7.app/sampleId" }] })
	test.isTrue(true, "addColumn accepts query spec")
}

TestAddColumnDetectsUnresolved := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved)
	b.addColumn(sampleRef)
	test.isTrue(true, "addColumn accepts unresolved PlRef")
}

TestAddColumnsAcceptsArray := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved)
	b.addColumns([sampleResolved, sampleResolved], { headerPrefix: "Seq: " })
	test.isTrue(true, "addColumns accepts array of resolved columns")
}

TestAddColumnsDetectsQuerySpec := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved)
	b.addColumns(
		{ axes: [{ anchor: "main", name: "id" }], namePattern: "metric/.*" },
		{ headerPrefix: "m_" })
	test.isTrue(true, "addColumns accepts query spec")
}

TestMultiplePrimaries := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved).
		addPrimary("other", sampleResolved)
	test.isTrue(true, "multiple addPrimary calls accepted")
}

// EnrichmentRef hops are either a global-form PObjectId string —
// canonicalize({__isRef: true, blockId, name}) — decoded by the workflow at
// build() time, or a pre-resolved {spec, data} map (used when the hop is sourced
// from prerun/outputs and was resolved on the model side).
sampleHitId := "{\"__isRef\":true,\"blockId\":\"b1\",\"name\":\"hit-1\"}"
sampleLinkerId := "{\"__isRef\":true,\"blockId\":\"b1\",\"name\":\"linker-1\"}"

TestAddColumnAcceptsEnrichmentRefWithGlobalIds := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleRef)
	b.addColumn({
		__isEnrichment: "v1",
		hit: sampleHitId,
		path: [{ type: "linker", linker: sampleLinkerId }]
	})
	test.isTrue(true, "addColumn accepts EnrichmentRef with global-form PObjectId hops")
}

TestAddColumnAcceptsEnrichmentRefWithResolvedHops := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleResolved)
	b.addColumn({
		__isEnrichment: "v1",
		hit: sampleResolved,
		path: [{ type: "linker", linker: sampleResolved }]
	})
	test.isTrue(true, "addColumn accepts EnrichmentRef with pre-resolved {spec, data} hops")
}

TestAddColumnAcceptsEnrichmentRefWithoutPath := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleRef)
	b.addColumn({ __isEnrichment: "v1", hit: sampleHitId })
	test.isTrue(true, "addColumn accepts zero-hop EnrichmentRef (path omitted)")
}

TestAddColumnsAcceptsArrayWithEnrichmentRef := func() {
	b := tb.tableBuilder("tsv")
	b.addPrimary("main", sampleRef)
	b.addColumns(
		[sampleResolved, { __isEnrichment: "v1", hit: sampleHitId, path: [] }],
		{ headerPrefix: "x_" })
	test.isTrue(true, "addColumns accepts array mixing resolved columns and EnrichmentRefs")
}

// Note on panic-on-misuse coverage: Tengo unit tests can't catch panics
// (`ll.panic` is terminal, no recover/try-catch). Misuse paths are guarded
// by `ll.assert` in the source — see the assertions in:
//   - tableBuilder(): VALID_FORMATS check
//   - addPrimary():    name is_string, value shape (resolved/PrimaryRef/PlRef-bearing)
//   - addColumns():    array elements must be resolved columns
//   - setJoinMode():   "inner"|"full" only
//   - setAxisHeader(): string-or-AxisSpec matcher, string header
//   - cacheInputs():   integer duration
//   - build():         len(primaries) > 0; ctx required when unresolved
// End-to-end panics (build-time) are covered by the integration tests below.
