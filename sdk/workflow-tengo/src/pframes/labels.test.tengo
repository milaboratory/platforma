test := import(":test")
json := import("json")
labels := import(":pframes.labels")
pSpec := import(":pframes.spec")

getLabel := func(spec) {
	if is_undefined(spec.annotations) {
		return undefined
	}
	return spec.annotations[pSpec.A_LABEL]
}

makeSpec := func(traceEntries, ...label) {
	annotations := {}
	if len(traceEntries) > 0 {
		annotations[pSpec.A_TRACE] = json.encode(traceEntries)
	}
	if len(label) > 0 {
		annotations[pSpec.A_LABEL] = label[0]
	}
	return {
		kind: "PColumn",
		name: "name",
		valueType: "Int",
		annotations: annotations,
		axesSpec: []
	}
}

makeLabeledSpec := func(traceEntries) {
	return makeSpec(traceEntries, "Label")
}

// --- Basic derivation (no options) ---

TestSimpleNoOptions := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "L1"}]),
		makeLabeledSpec([{type: "t1", label: "L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["L1", "L2"], result)
}

TestLaterWinsNoOptions := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L1"}]),
		makeLabeledSpec([{type: "t1", label: "T1L2"}, {type: "t2", label: "T2L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["T2L1", "T2L2"], result)
}

TestImportanceWinsNoOptions := func() {
	specs := [
		makeLabeledSpec([{type: "t1", importance: 100, label: "T1L1"}, {type: "t2", label: "T2L1"}]),
		makeLabeledSpec([{type: "t1", importance: 100, label: "T1L2"}, {type: "t2", label: "T2L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["T1L1", "T1L2"], result)
}

TestUniquenessWinsNoOptions := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L1"}]),
		makeLabeledSpec([{type: "t1", label: "T1L2"}, {type: "t2", label: "T2L1"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["T1L1", "T1L2"], result)
}

TestCombinatoricSolutionNoOptions := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L1"}]),
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L2"}]),
		makeLabeledSpec([{type: "t1", label: "T1L2"}, {type: "t2", label: "T2L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["T1L1 / T2L1", "T1L1 / T2L2", "T1L2 / T2L2"], result)
}

// --- includeNativeLabel ---

TestSimpleWithNativeLabel := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "L1"}]),
		makeLabeledSpec([{type: "t1", label: "L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel, { includeNativeLabel: true })
	test.isEqual(["Label / L1", "Label / L2"], result)
}

TestCombinatoricWithNativeLabel := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L1"}]),
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L2"}]),
		makeLabeledSpec([{type: "t1", label: "T1L2"}, {type: "t2", label: "T2L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel, { includeNativeLabel: true })
	test.isEqual(["Label / T1L1 / T2L1", "Label / T1L1 / T2L2", "Label / T1L2 / T2L2"], result)
}

// --- Minimization ---

TestMinimizationRemovesRedundantType := func() {
	specs := [
		makeLabeledSpec([{type: "t1", importance: 10, label: "High1"}, {type: "t2", importance: 1, label: "Low1"}]),
		makeLabeledSpec([{type: "t1", importance: 10, label: "High2"}, {type: "t2", importance: 1, label: "Low2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["High1", "High2"], result)
}

TestMinimizationKeepsBothWhenNeeded := func() {
	specs := [
		makeLabeledSpec([{type: "t1", importance: 10, label: "A"}, {type: "t2", importance: 1, label: "X"}]),
		makeLabeledSpec([{type: "t1", importance: 10, label: "A"}, {type: "t2", importance: 1, label: "Y"}]),
		makeLabeledSpec([{type: "t1", importance: 10, label: "B"}, {type: "t2", importance: 1, label: "Y"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["A / X", "A / Y", "B / Y"], result)
}

TestMinimizationRemovesMultipleRedundant := func() {
	specs := [
		makeLabeledSpec([{type: "t1", importance: 100, label: "Unique1"}, {type: "t2", importance: 10, label: "Same"}, {type: "t3", importance: 1, label: "Same"}]),
		makeLabeledSpec([{type: "t1", importance: 100, label: "Unique2"}, {type: "t2", importance: 10, label: "Same"}, {type: "t3", importance: 1, label: "Same"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["Unique1", "Unique2"], result)
}

TestMinimizationFallback := func() {
	specs := [
		makeLabeledSpec([{type: "t1", importance: 100, label: "A"}, {type: "t2", importance: 10, label: "X"}, {type: "t3", importance: 1, label: "Same"}]),
		makeLabeledSpec([{type: "t1", importance: 100, label: "A"}, {type: "t2", importance: 10, label: "X"}, {type: "t3", importance: 1, label: "Same"}]),
		makeLabeledSpec([{type: "t1", importance: 100, label: "B"}, {type: "t2", importance: 10, label: "Y"}, {type: "t3", importance: 1, label: "Same"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["A", "A", "B"], result)
}

// --- Fallback and edge cases ---

TestFallbackToNativeLabels := func() {
	specs := [makeLabeledSpec([]), makeLabeledSpec([])]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["Label", "Label"], result)
}

TestSingleValue := func() {
	specs := [makeLabeledSpec([{type: "t1", label: "Only"}])]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["Only"], result)
}

TestUnlabeledFallback := func() {
	specs := [makeSpec([]), makeSpec([])]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["Unlabeled", "Unlabeled"], result)
}

TestRepeatedTypeOccurrences := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "First"}, {type: "t1", label: "A"}]),
		makeLabeledSpec([{type: "t1", label: "First"}, {type: "t1", label: "B"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["A", "B"], result)
}

TestMixedCommonAndDifferent := func() {
	specs := [
		makeLabeledSpec([
			{type: "commonType", importance: 1, id: "common", label: "Common entry"},
			{type: "uniqueType", importance: 10, id: "id1", label: "Unique entry 1"}
		]),
		makeLabeledSpec([
			{type: "commonType", importance: 1, id: "common", label: "Common entry"},
			{type: "uniqueType", importance: 5, id: "id2", label: "Unique entry 2"}
		])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["Unique entry 1", "Unique entry 2"], result)
}

TestSpecWithoutNativeLabel := func() {
	specs := [
		makeSpec([{type: "t1", label: "X"}]),
		makeSpec([{type: "t1", label: "Y"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel)
	test.isEqual(["X", "Y"], result)
}

TestIncludeNativeLabelWithNoLabel := func() {
	specs := [
		makeSpec([{type: "t1", label: "X"}]),
		makeSpec([{type: "t1", label: "Y"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel, { includeNativeLabel: true })
	test.isEqual(["X", "Y"], result)
}

// --- addLabelAsSuffix ---

TestAddLabelAsSuffix := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "L1"}]),
		makeLabeledSpec([{type: "t1", label: "L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel, { includeNativeLabel: true, addLabelAsSuffix: true })
	test.isEqual(["L1 / Label", "L2 / Label"], result)
}

// --- custom separator ---

TestCustomSeparator := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "A"}, {type: "t2", label: "X"}]),
		makeLabeledSpec([{type: "t1", label: "A"}, {type: "t2", label: "Y"}]),
		makeLabeledSpec([{type: "t1", label: "B"}, {type: "t2", label: "Y"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel, { separator: " - " })
	test.isEqual(["A - X", "A - Y", "B - Y"], result)
}

// --- forceTraceElements ---

TestForceOneElement := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L1"}]),
		makeLabeledSpec([{type: "t1", label: "T1L2"}, {type: "t2", label: "T2L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel, { forceTraceElements: ["t1"] })
	test.isEqual(["T1L1", "T1L2"], result)
}

TestForceMultipleElements := func() {
	specs := [
		makeLabeledSpec([{type: "t1", label: "T1L1"}, {type: "t2", label: "T2L1"}, {type: "t3", label: "T3L1"}]),
		makeLabeledSpec([{type: "t1", label: "T1L2"}, {type: "t2", label: "T2L2"}, {type: "t3", label: "T3L2"}])
	]
	result := labels.deriveDistinctLabels(specs, getLabel, { forceTraceElements: ["t1", "t3"] })
	test.isEqual(["T1L1 / T3L1", "T1L2 / T3L2"], result)
}

// --- linkerPath ---

TestLinkerPathDefaultSuffix := func() {
	entries := [
		{
			spec: makeSpec([{type: "t1", label: "Col1"}]),
			linkerPath: [{ spec: { annotations: { "pl7.app/linkLabel": "MyLinker" } } }]
		},
		makeSpec([{type: "t1", label: "Col2"}])
	]
	result := labels.deriveDistinctLabels(entries, getLabel)
	test.isEqual(["Col1 via MyLinker", "Col2"], result)
}

TestLinkerPathMultipleSteps := func() {
	entries := [
		{
			spec: makeSpec([{type: "t1", label: "Col1"}]),
			linkerPath: [
				{ spec: { annotations: { "pl7.app/linkLabel": "L1" } } },
				{ spec: { annotations: { "pl7.app/linkLabel": "L2" } } }
			]
		},
		makeSpec([{type: "t1", label: "Col2"}])
	]
	result := labels.deriveDistinctLabels(entries, getLabel)
	test.isEqual(["Col1 via L1 > L2", "Col2"], result)
}

TestLinkerPathFallsBackToLabel := func() {
	entries := [
		{
			spec: makeSpec([{type: "t1", label: "Col1"}]),
			linkerPath: [{ spec: { annotations: { "pl7.app/label": "FallbackLabel" } } }]
		},
		makeSpec([{type: "t1", label: "Col2"}])
	]
	result := labels.deriveDistinctLabels(entries, getLabel)
	test.isEqual(["Col1 via FallbackLabel", "Col2"], result)
}

TestLinkerPathSkipsEmptyLabels := func() {
	entries := [
		{
			spec: makeSpec([{type: "t1", label: "Col1"}]),
			linkerPath: [
				{ spec: { annotations: {} } },
				{ spec: { annotations: { "pl7.app/linkLabel": "L2" } } }
			]
		},
		makeSpec([{type: "t1", label: "Col2"}])
	]
	result := labels.deriveDistinctLabels(entries, getLabel)
	test.isEqual(["Col1 via L2", "Col2"], result)
}

TestLinkerPathCustomFormatter := func() {
	entries := [
		{
			spec: makeSpec([{type: "t1", label: "Col1"}]),
			linkerPath: [{ spec: { annotations: { "pl7.app/linkLabel": "L1" } } }]
		},
		makeSpec([{type: "t1", label: "Col2"}])
	]
	formatter := func(linkerLabels, spec, index) {
		return "[" + linkerLabels[0] + "]"
	}
	result := labels.deriveDistinctLabels(entries, getLabel, { linkerLabelFormatter: formatter })
	test.isEqual(["Col1 [L1]", "Col2"], result)
}

TestLinkerPathFormatterReturningUndefined := func() {
	entries := [
		{
			spec: makeSpec([{type: "t1", label: "Col1"}]),
			linkerPath: [{ spec: { annotations: { "pl7.app/linkLabel": "L1" } } }]
		},
		makeSpec([{type: "t1", label: "Col2"}])
	]
	formatter := func(linkerLabels, spec, index) {
		return undefined
	}
	result := labels.deriveDistinctLabels(entries, getLabel, { linkerLabelFormatter: formatter })
	test.isEqual(["Col1", "Col2"], result)
}

// --- extraTrace ---

TestExtraTraceSuffix := func() {
	spec := makeSpec([{type: "t1", label: "Base"}])
	entries := [
		{ spec: spec, extraTrace: [{type: "suffix", label: "S1"}] },
		{ spec: spec, extraTrace: [{type: "suffix", label: "S2"}] }
	]
	result := labels.deriveDistinctLabels(entries, getLabel)
	test.isEqual(["S1", "S2"], result)
}

TestExtraTracePrefix := func() {
	spec := makeSpec([{type: "t1", label: "Base"}])
	entries := [
		{ spec: spec, extraTrace: [{type: "prefix", label: "P1", position: "prefix"}] },
		{ spec: spec, extraTrace: [{type: "prefix", label: "P2", position: "prefix"}] }
	]
	result := labels.deriveDistinctLabels(entries, getLabel)
	test.isEqual(["P1", "P2"], result)
}
