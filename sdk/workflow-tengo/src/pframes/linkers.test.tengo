test := import(":test")
linkers := import(":pframes.linkers")
pSpec := import(":pframes.spec")

TestLinkerSingleMatchQuery := func() {
	spec := {
		kind: "PColumn",
		name: "pl7.app/linker",
		valueType: "Int",
		domain: { "pl7.app/block": "block1" },
		axesSpec: [
			{ name: "clonotypeKey", type: "String", domain: { "pl7.app/species": "human" } },
			{ name: "clusterId", type: "String", domain: { "pl7.app/block": "cluster1" } }
		]
	}
	result := linkers.linkerSingleMatchQuery(spec)
	test.isEqual("pl7.app/linker", result.name)
	test.isEqual(2, len(result.axes))
	test.isEqual("clonotypeKey", result.axes[0].name)
	test.isEqual("String", result.axes[0].type)
	test.isEqual({ "pl7.app/species": "human" }, result.axes[0].domain)
	test.isEqual("clusterId", result.axes[1].name)
	test.isEqual({ "pl7.app/block": "cluster1" }, result.axes[1].domain)
	test.isEqual({ "pl7.app/block": "block1" }, result.domain)
}

TestLinkerSingleMatchQueryNoDomain := func() {
	spec := {
		kind: "PColumn",
		name: "pl7.app/linker",
		valueType: "Int",
		domain: {},
		axesSpec: [
			{ name: "axis1", type: "String" },
			{ name: "axis2", type: "Int" }
		]
	}
	result := linkers.linkerSingleMatchQuery(spec)
	test.isEqual("pl7.app/linker", result.name)
	test.isTrue(is_undefined(result.domain))
	test.isTrue(is_undefined(result.axes[0].domain))
}

TestBuildLinkedSelector := func() {
	axisSpec := { name: "clusterId", type: "String", domain: { "pl7.app/block": "block1" } }
	result := linkers.buildLinkedSelector(axisSpec)
	test.isEqual(1, len(result.axes))
	test.isEqual("clusterId", result.axes[0].name)
	test.isEqual("String", result.axes[0].type)
	test.isEqual({ "pl7.app/block": "block1" }, result.axes[0].domain)
}

TestBuildLinkedSelectorNoDomain := func() {
	axisSpec := { name: "clusterId", type: "Int" }
	result := linkers.buildLinkedSelector(axisSpec)
	test.isEqual(1, len(result.axes))
	test.isTrue(is_undefined(result.axes[0].domain))
}

TestMakeColumnKey := func() {
	spec1 := { name: "col1" }
	spec2 := { name: "col1", domain: { "pl7.app/block": "b1" } }
	spec3 := { name: "col1", domain: {} }

	key1 := pSpec.makeColumnKey(spec1)
	key2 := pSpec.makeColumnKey(spec2)
	key3 := pSpec.makeColumnKey(spec3)

	// Empty domain treated as absent
	test.isEqual(key1, key3)
	// Non-empty domain produces different key
	test.isTrue(key1 != key2)
}
