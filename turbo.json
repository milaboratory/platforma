{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["tsconfig.json"],
  "tasks": {
    "fmt": {
      "outputs": [],
      "inputs": [
        ".oxfmtrc.json",
        ".oxlintrc.json",
        "$TURBO_DEFAULT$",
        "!**/*.md",
        "!**/.gitignore",
        "!**/LICENSE"
      ]
    },
    "check": {
      "outputs": [],
      "inputs": [
        ".oxfmtrc.json",
        ".oxlintrc.json",
        "$TURBO_DEFAULT$",
        "tsconfig.json",
        "!**/*.md",
        "!**/.gitignore",
        "!**/LICENSE"
      ],
      "dependsOn": ["^build"]
    },
    "formatter:check": {
      "outputs": [],
      "inputs": [".oxfmtrc.json", "$TURBO_DEFAULT$", "!**/*.md", "!**/.gitignore", "!**/LICENSE"]
    },
    "linter:check": {
      "outputs": [],
      "inputs": [".oxlintrc.json", "$TURBO_DEFAULT$", "!**/*.md", "!**/.gitignore", "!**/LICENSE"]
    },
    "types:check": {
      "outputs": [],
      "inputs": ["tsconfig.json", "$TURBO_DEFAULT$", "!**/*.md", "!**/.gitignore", "!**/LICENSE"],
      "dependsOn": ["^build"]
    },
    "build": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/.gitignore", "!**/LICENSE"],
      "outputs": ["./dist/**", "./block-pack/**", "./pkg-*.tgz"],
      "env": [],
      "dependsOn": ["^build", "types:check"],
      "passThroughEnv": [
        "GENERATE_TAGS",
        "TAGS_ADDITIONAL_ARGS",
        "TAGS_FILE",
        "PL_DOCKER_REGISTRY_PUSH_TO",
        "PL_DOCKER_BUILD",
        "PL_DOCKER_NO_BUILD",
        "PL_DOCKER_AUTOPUSH",
        "PL_DOCKER_NO_AUTOPUSH"
      ]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/.gitignore", "!**/LICENSE"],
      "env": ["TEST_CACHE_CRUTCH"],
      "outputs": ["./coverage/**", "test-report.junit.xml"],
      "dependsOn": ["build"],
      "passThroughEnv": [
        "PL_ADDRESS",
        "PL_TEST_PASSWORD",
        "PL_TEST_USER",
        "PL_TEST_PROXY",
        "PL_TEST_STORAGE_ID",
        "DEBUG",
        "MI_LICENSE",
        "PL_DOCKER_REGISTRY_PUSH_TO",
        "PL_DOCKER_BUILD",
        "PL_DOCKER_NO_BUILD",
        "PL_DOCKER_AUTOPUSH",
        "PL_DOCKER_NO_AUTOPUSH"
      ]
    },
    "do-pack": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!**/.gitignore", "!**/LICENSE"],
      "dependsOn": ["build"],
      "outputs": ["package.tgz"]
    }
  }
}
